{
    "name": "bvp/scraper",
    "description": "Boatrace Vibe Project Scraper",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "boatrace",
        "library",
        "scraper"
    ],
    "authors": [
        {
            "name": "shimomo",
            "email": "bvp@shimomo.net"
        }
    ],
    "support": {
        "issues": "https://github.com/boatracevibeproject/scraper/issues",
        "source": "https://github.com/boatracevibeproject/scraper"
    },
    "require": {
        "php": "^8.3",
        "nesbot/carbon": "^2.63 || ^3.0",
        "psr/simple-cache": "^3.0",
        "symfony/browser-kit": "^7.0 || ^8.0",
        "symfony/cache": "^7.0 || ^8.0",
        "symfony/css-selector": "^7.0 || ^8.0",
        "symfony/http-client": "^7.0 || ^8.0"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.52",
        "phpunit/phpunit": "^12.0 || ^13.0",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "BVP\\Scraper\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BVP\\Scraper\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true
        }
    },
    "$schema": "https://getcomposer.org/schema.json"
}
